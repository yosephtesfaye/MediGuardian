# MediGuardian AI — Environment Configuration
# Copy to .env and fill in values

APP_NAME=MediGuardian AI
APP_VERSION=1.0.0
APP_ENV=development

# Required for AI chat, OCR, and embeddings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Database (SQLite dev / PostgreSQL prod)
DATABASE_URL=sqlite:///./mediguardian.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/mediguardian

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
RATE_LIMIT=60/minute
UPLOAD_MAX_MB=10
TTS_ENABLED=true
